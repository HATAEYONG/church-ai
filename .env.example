# ─────────────────────────────────────────────────────────────
# 환경 변수
# 이 파일을 .env.local 로 복사한 뒤 값을 채워주세요.
# ─────────────────────────────────────────────────────────────

# Supabase (인증 + 데이터베이스)
# https://supabase.com/dashboard 프로젝트 > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Claude API (AI 신앙 멘토)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# AI 멘토에 사용할 모델 (기본값: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI API (대체 AI 제공자) — 선택
# 설정에서 검색순서로 Claude/OpenAI 우선순위를 정할 수 있습니다. https://platform.openai.com/
OPENAI_API_KEY=
# OpenAI 모델 (기본값: gpt-4o)
OPENAI_MODEL=gpt-4o

# Google Gemini API (대체 AI 제공자, OpenAI 호환 엔드포인트 사용) — 선택
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Gemini 모델 (기본값: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# ElevenLabs (음성 합성 / 보이스 클로닝) — 선택
# 음성 기능을 사용하려면 설정하세요. https://elevenlabs.io > Settings > API Keys
# 주의: 이 키는 서버 전용입니다(NEXT_PUBLIC_ 접두사 금지).
ELEVENLABS_API_KEY=
